<script>
$(function(){
//서브 navi 메뉴 시작
	var depthNum1 = $("#navi .navi-box").data("depth1");
	var depthNum2 = $("#navi .navi-box").data("depth2");
//	$(".depth-1").on("click",function(){
//		$(this).addClass("on");
//		$(".main-depth").stop().slideToggle();
//	});
//	$(".main-depth li a").on("click",function(e){
//		e.preventDefault();
//		depthNum1 = $(this).data("depth");
//		alert(depthNum1);
//		$(".main-depth").stop().slideUp();
//	});
	$(".depth-1").on("click",function(){
		if($(this).hasClass("on")){
			$(this).removeClass("on");
			$(".main-depth").stop().slideUp();
		}else{
			$(this).addClass("on");
			$(".main-depth").stop().slideDown();
		}
	});

	$(".depth-2").on("click",function(){
		if($(this).hasClass("on")){
			$(this).removeClass("on");
			$(".sub-depth" + depthNum1).stop().slideUp();
		}else{
			$(this).addClass("on");
			$(".sub-depth" + depthNum1).stop().slideDown();
		}
	});

	$(document).mouseup(function (e){
	  var LayerPopup = $(".depth-2");
	  if(LayerPopup.has(e.target).length === 0){
		LayerPopup.removeClass("on");
		$(".sub-depth" + depthNum1).stop().slideUp();
	  }
	});

	$("#navi .depth-1 .name").text($(".main-depth li").eq(depthNum1-1).children().text());
	$("#navi .depth-2 .plus-minus").before($(".sub-depth"+depthNum1+" li").eq(depthNum2-1).children().text());

//서브 navi 메뉴 끝
});
</script>